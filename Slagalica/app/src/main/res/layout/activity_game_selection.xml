<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="#F5F5F5">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="24dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Izbor igre"
            android:textSize="30sp"
            android:textStyle="bold"
            android:textColor="#1E1E1E"
            android:layout_marginTop="40dp"
            android:layout_marginBottom="32dp" />

        <Button
            android:id="@+id/btnOpenKorakPoKorak"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:text="Korak po korak"
            android:textAllCaps="false"
            android:textSize="16sp"
            android:layout_marginBottom="16dp" />

        <Button
            android:id="@+id/btnOpenMojBroj"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:text="Moj broj"
            android:textAllCaps="false"
            android:textSize="16sp"
            android:layout_marginBottom="16dp" />

        <Button
            android:id="@+id/btnOpenKoZnaZna"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:text="Ko zna zna"
            android:textAllCaps="false"
            android:textSize="16sp"
            android:layout_marginBottom="16dp" />

        <Button
            android:id="@+id/btnOpenSpojnice"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:text="Spojnice"
            android:textAllCaps="false"
            android:textSize="16sp"
            android:layout_marginBottom="16dp" />

        <Button
            android:id="@+id/btnOpenAsocijacije"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:text="Asocijacije"
            android:textAllCaps="false"
            android:textSize="16sp"
            android:layout_marginBottom="16dp" />

        <Button
            android:id="@+id/btnOpenSkocko"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:text="Skočko"
            android:textAllCaps="false"
            android:textSize="16sp"
            android:layout_marginBottom="32dp" />

        <Button
            android:id="@+id/btnBack"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:text="Nazad"
            android:textAllCaps="false"
            android:textSize="16sp" />

    </LinearLayout>

</ScrollView>
