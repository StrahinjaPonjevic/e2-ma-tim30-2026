<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/tvChallengeDetailTitle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Izazov"
                android:textColor="#1E1E1E"
                android:textSize="26sp"
                android:textStyle="bold" />

            <Button
                android:id="@+id/btnChallengeDetailBack"
                android:layout_width="wrap_content"
                android:layout_height="48dp"
                android:text="Nazad"
                android:textAllCaps="false" />
        </LinearLayout>

        <TextView
            android:id="@+id/tvChallengeInfo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:text="Info"
            android:textColor="#333333"
            android:textSize="16sp" />

        <TextView
            android:id="@+id/tvChallengeParticipants"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:background="#FFFFFF"
            android:padding="12dp"
            android:text="Ucesnici"
            android:textColor="#333333"
            android:textSize="16sp" />

        <TextView
            android:id="@+id/tvChallengeResult"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:text="Rezultat"
            android:textColor="#6200EE"
            android:textSize="17sp"
            android:textStyle="bold" />

        <LinearLayout
            android:id="@+id/scoreInputs"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:orientation="vertical"
            android:visibility="gone">

            <EditText
                android:id="@+id/etScoreKoZnaZna"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:hint="Ko zna zna score"
                android:inputType="number"
                android:padding="10dp" />

            <EditText
                android:id="@+id/etScoreSpojnice"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:hint="Spojnice score"
                android:inputType="number"
                android:padding="10dp" />

            <EditText
                android:id="@+id/etScoreAsocijacije"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:hint="Asocijacije score"
                android:inputType="number"
                android:padding="10dp" />

            <EditText
                android:id="@+id/etScoreSkocko"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:hint="Skocko score"
                android:inputType="number"
                android:padding="10dp" />

            <EditText
                android:id="@+id/etScoreKorak"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:hint="Korak po korak score"
                android:inputType="number"
                android:padding="10dp" />

            <EditText
                android:id="@+id/etScoreMojBroj"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:hint="Moj broj score"
                android:inputType="number"
                android:padding="10dp" />
        </LinearLayout>

        <Button
            android:id="@+id/btnChallengePrimary"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:layout_marginTop="18dp"
            android:text="Akcija"
            android:textAllCaps="false" />

        <Button
            android:id="@+id/btnSubmitChallengeScore"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:layout_marginTop="12dp"
            android:text="Posalji solo set rezultat"
            android:textAllCaps="false"
            android:visibility="gone" />
    </LinearLayout>
</ScrollView>
