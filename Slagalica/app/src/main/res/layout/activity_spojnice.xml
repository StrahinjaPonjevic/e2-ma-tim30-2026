<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F5F5F5">

    <include layout="@layout/view_game_header" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="#F5F5F5">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Izaberi pojam iz leve kolone, pa odgovarajuci pojam iz desne kolone."
                android:textSize="16sp"
                android:textColor="#555555"
                android:gravity="center"
                android:layout_marginBottom="20dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="20dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginEnd="8dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Leva kolona"
                        android:textStyle="bold"
                        android:textSize="16sp"
                        android:gravity="center"
                        android:layout_marginBottom="8dp" />

                    <Button
                        android:id="@+id/btnLeft1"
                        android:layout_width="match_parent"
                        android:layout_height="55dp"
                        android:text="Nikola Tesla"
                        android:textAllCaps="false"
                        android:textSize="14sp"
                        android:textColor="#1E1E1E"
                        android:layout_marginBottom="8dp" />

                    <Button
                        android:id="@+id/btnLeft2"
                        android:layout_width="match_parent"
                        android:layout_height="55dp"
                        android:text="Novak Djokovic"
                        android:textAllCaps="false"
                        android:textSize="14sp"
                        android:textColor="#1E1E1E"
                        android:layout_marginBottom="8dp" />

                    <Button
                        android:id="@+id/btnLeft3"
                        android:layout_width="match_parent"
                        android:layout_height="55dp"
                        android:text="Ivo Andric"
                        android:textAllCaps="false"
                        android:textSize="14sp"
                        android:textColor="#1E1E1E"
                        android:layout_marginBottom="8dp" />

                    <Button
                        android:id="@+id/btnLeft4"
                        android:layout_width="match_parent"
                        android:layout_height="55dp"
                        android:text="Mocart"
                        android:textAllCaps="false"
                        android:textSize="14sp"
                        android:textColor="#1E1E1E"
                        android:layout_marginBottom="8dp" />

                    <Button
                        android:id="@+id/btnLeft5"
                        android:layout_width="match_parent"
                        android:layout_height="55dp"
                        android:text="Albert Einstein"
                        android:textAllCaps="false"
                        android:textSize="14sp"
                        android:textColor="#1E1E1E" />

                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginStart="8dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Desna kolona"
                        android:textStyle="bold"
                        android:textSize="16sp"
                        android:gravity="center"
                        android:layout_marginBottom="8dp" />

                    <Button
                        android:id="@+id/btnRight1"
                        android:layout_width="match_parent"
                        android:layout_height="55dp"
                        android:text="Tenis"
                        android:textAllCaps="false"
                        android:textSize="14sp"
                        android:textColor="#1E1E1E"
                        android:layout_marginBottom="8dp" />

                    <Button
                        android:id="@+id/btnRight2"
                        android:layout_width="match_parent"
                        android:layout_height="55dp"
                        android:text="Relativnost"
                        android:textAllCaps="false"
                        android:textSize="14sp"
                        android:textColor="#1E1E1E"
                        android:layout_marginBottom="8dp" />

                    <Button
                        android:id="@+id/btnRight3"
                        android:layout_width="match_parent"
                        android:layout_height="55dp"
                        android:text="Naizmenicna struja"
                        android:textAllCaps="false"
                        android:textSize="14sp"
                        android:textColor="#1E1E1E"
                        android:layout_marginBottom="8dp" />

                    <Button
                        android:id="@+id/btnRight4"
                        android:layout_width="match_parent"
                        android:layout_height="55dp"
                        android:text="Muzika"
                        android:textAllCaps="false"
                        android:textSize="14sp"
                        android:textColor="#1E1E1E"
                        android:layout_marginBottom="8dp" />

                    <Button
                        android:id="@+id/btnRight5"
                        android:layout_width="match_parent"
                        android:layout_height="55dp"
                        android:text="Na Drini cuprija"
                        android:textAllCaps="false"
                        android:textSize="14sp"
                        android:textColor="#1E1E1E" />

                </LinearLayout>
            </LinearLayout>

            <TextView
                android:id="@+id/tvSelected"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Izabrano: nista"
                android:textSize="16sp"
                android:textColor="#333333"
                android:gravity="center"
                android:layout_marginBottom="20dp" />

            <Button
                android:id="@+id/btnNextRound"
                android:layout_width="match_parent"
                android:layout_height="55dp"
                android:text="Sledeca runda"
                android:textAllCaps="false"
                android:textSize="16sp"
                android:layout_marginBottom="12dp" />

            <Button
                android:id="@+id/btnBack"
                android:layout_width="match_parent"
                android:layout_height="55dp"
                android:text="Nazad"
                android:textAllCaps="false"
                android:textSize="16sp" />

        </LinearLayout>
    </ScrollView>

</LinearLayout>
