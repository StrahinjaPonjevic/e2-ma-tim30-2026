<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="#F5F5F5">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Moj broj"
            android:textSize="30sp"
            android:textStyle="bold"
            android:textColor="#1E1E1E"
            android:gravity="center"
            android:layout_marginBottom="8dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Pomoću ponuđenih brojeva i operacija dođite do traženog broja"
            android:textSize="15sp"
            android:textColor="#666666"
            android:gravity="center"
            android:layout_marginBottom="24dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Runda: 1/2"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#1E1E1E" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Vreme: 60s"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#1E1E1E"
                android:gravity="end" />

        </LinearLayout>

        <TextView
            android:id="@+id/tvTargetNumber"
            android:layout_width="match_parent"
            android:layout_height="70dp"
            android:text="Traženi broj: ---"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="#1E1E1E"
            android:gravity="center"
            android:background="@android:drawable/edit_text"
            android:layout_marginBottom="12dp" />

        <Button
            android:id="@+id/btnStopTargetNumber"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:text="STOP za traženi broj"
            android:textAllCaps="false"
            android:textSize="16sp"
            android:layout_marginBottom="20dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Ponuđeni brojevi"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#1E1E1E"
            android:layout_marginBottom="10dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:orientation="horizontal"
            android:layout_marginBottom="12dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:text="-"
                android:textSize="20sp"
                android:gravity="center"
                android:background="@android:drawable/edit_text"
                android:layout_marginEnd="4dp" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:text="-"
                android:textSize="20sp"
                android:gravity="center"
                android:background="@android:drawable/edit_text"
                android:layout_marginEnd="4dp" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:text="-"
                android:textSize="20sp"
                android:gravity="center"
                android:background="@android:drawable/edit_text"
                android:layout_marginEnd="4dp" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:text="-"
                android:textSize="20sp"
                android:gravity="center"
                android:background="@android:drawable/edit_text"
                android:layout_marginEnd="4dp" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:text="-"
                android:textSize="20sp"
                android:gravity="center"
                android:background="@android:drawable/edit_text"
                android:layout_marginEnd="4dp" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:text="-"
                android:textSize="20sp"
                android:gravity="center"
                android:background="@android:drawable/edit_text" />

        </LinearLayout>

        <Button
            android:id="@+id/btnStopNumbers"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:text="STOP za ponuđene brojeve"
            android:textAllCaps="false"
            android:textSize="16sp"
            android:layout_marginBottom="20dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Dostupne operacije: +  -  *  /  (  )"
            android:textSize="16sp"
            android:textColor="#333333"
            android:gravity="center"
            android:layout_marginBottom="16dp" />

        <EditText
            android:id="@+id/etExpression"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:hint="Unesite izraz, npr. (100 + 25) * 2"
            android:inputType="text"
            android:padding="12dp"
            android:background="@android:drawable/edit_text"
            android:layout_marginBottom="12dp" />

        <TextView
            android:id="@+id/tvExpressionResult"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Rezultat izraza: ---"
            android:textSize="16sp"
            android:textColor="#333333"
            android:gravity="center"
            android:layout_marginBottom="16dp" />

        <Button
            android:id="@+id/btnConfirmExpression"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:text="Potvrdi izraz"
            android:textAllCaps="false"
            android:textSize="16sp"
            android:layout_marginBottom="12dp" />

        <Button
            android:id="@+id/btnClearExpression"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:text="Obriši izraz"
            android:textAllCaps="false"
            android:textSize="16sp"
            android:layout_marginBottom="12dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Napomena: U finalnoj verziji brojevi će moći da se zaustave klikom na STOP ili protresanjem telefona."
            android:textSize="13sp"
            android:textColor="#777777"
            android:gravity="center"
            android:layout_marginBottom="16dp" />

        <Button
            android:id="@+id/btnGiveUpMojBroj"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:text="Odustani"
            android:textAllCaps="false"
            android:textSize="16sp" />

    </LinearLayout>

</ScrollView>