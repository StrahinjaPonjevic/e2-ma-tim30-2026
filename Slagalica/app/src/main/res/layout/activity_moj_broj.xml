<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5"
    android:fitsSystemWindows="true"
    android:paddingStart="24dp"
    android:paddingTop="14dp"
    android:paddingEnd="24dp"
    android:paddingBottom="14dp">

    <TextView
        android:id="@+id/tvGameTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Moj broj"
        android:textColor="#1E1E1E"
        android:textSize="24sp"
        android:textStyle="bold"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/tvRound"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="24dp"
        android:text="Runda: 1/2"
        android:textColor="#1E1E1E"
        android:textSize="15sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toBottomOf="@id/tvGameTitle"
        app:layout_constraintStart_toEndOf="@id/tvGameTitle"
        app:layout_constraintTop_toTopOf="@id/tvGameTitle" />

    <TextView
        android:id="@+id/tvTimer"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Vreme: 60s"
        android:textColor="#1E1E1E"
        android:textSize="15sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toBottomOf="@id/tvGameTitle"
        app:layout_constraintEnd_toEndOf="@id/mainArea"
        app:layout_constraintTop_toTopOf="@id/tvGameTitle" />

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/mainArea"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="12dp"
        android:layout_marginEnd="18dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toStartOf="@id/operatorPanel"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvGameTitle">

        <TextView
            android:id="@+id/tvTargetNumber"
            android:layout_width="0dp"
            android:layout_height="54dp"
            android:background="@android:drawable/edit_text"
            android:gravity="center"
            android:text="Trazeni broj: ---"
            android:textColor="#1E1E1E"
            android:textSize="23sp"
            android:textStyle="bold"
            app:layout_constraintEnd_toStartOf="@id/tvCurrentResult"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/tvCurrentResult"
            android:layout_width="130dp"
            android:layout_height="54dp"
            android:layout_marginStart="10dp"
            android:background="@android:drawable/edit_text"
            android:gravity="center"
            android:text="= ---"
            android:textColor="#1E1E1E"
            android:textSize="22sp"
            android:textStyle="bold"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@id/tvTargetNumber"
            app:layout_constraintTop_toTopOf="parent" />

        <LinearLayout
            android:id="@+id/numbersRow"
            android:layout_width="0dp"
            android:layout_height="58dp"
            android:layout_marginTop="14dp"
            android:orientation="horizontal"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tvTargetNumber">

            <Button
                android:id="@+id/btnNumber1"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_marginEnd="6dp"
                android:layout_weight="1"
                android:enabled="false"
                android:text="-"
                android:textAllCaps="false"
                android:textSize="18sp"
                android:textStyle="bold" />

            <Button
                android:id="@+id/btnNumber2"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_marginEnd="6dp"
                android:layout_weight="1"
                android:enabled="false"
                android:text="-"
                android:textAllCaps="false"
                android:textSize="18sp"
                android:textStyle="bold" />

            <Button
                android:id="@+id/btnNumber3"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_marginEnd="6dp"
                android:layout_weight="1"
                android:enabled="false"
                android:text="-"
                android:textAllCaps="false"
                android:textSize="18sp"
                android:textStyle="bold" />

            <Button
                android:id="@+id/btnNumber4"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_marginEnd="6dp"
                android:layout_weight="1"
                android:enabled="false"
                android:text="-"
                android:textAllCaps="false"
                android:textSize="18sp"
                android:textStyle="bold" />

            <Button
                android:id="@+id/btnNumber5"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_marginEnd="6dp"
                android:layout_weight="1"
                android:enabled="false"
                android:text="-"
                android:textAllCaps="false"
                android:textSize="18sp"
                android:textStyle="bold" />

            <Button
                android:id="@+id/btnNumber6"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:enabled="false"
                android:text="-"
                android:textAllCaps="false"
                android:textSize="18sp"
                android:textStyle="bold" />
        </LinearLayout>

        <TextView
            android:id="@+id/tvExpressionValue"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_marginTop="14dp"
            android:background="@android:drawable/edit_text"
            android:gravity="center_vertical"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            android:singleLine="true"
            android:text="Izraz: "
            android:textColor="#1E1E1E"
            android:textSize="20sp"
            app:layout_constraintEnd_toStartOf="@id/btnClearExpression"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/numbersRow" />

        <Button
            android:id="@+id/btnClearExpression"
            android:layout_width="64dp"
            android:layout_height="56dp"
            android:layout_marginStart="5dp"
            android:text="⌫"
            android:textAllCaps="false"
            android:textSize="12sp"
            android:textStyle="bold"
            app:layout_constraintBottom_toBottomOf="@id/tvExpressionValue"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@id/tvExpressionValue"
            app:layout_constraintTop_toTopOf="@id/tvExpressionValue" />

        <Button
            android:id="@+id/btnConfirmExpression"
            android:layout_width="0dp"
            android:layout_height="50dp"
            android:layout_marginTop="12dp"
            android:text="STOP"
            android:textAllCaps="false"
            android:textSize="16sp"
            android:textStyle="bold"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tvExpressionValue" />
    </androidx.constraintlayout.widget.ConstraintLayout>

    <GridLayout
        android:id="@+id/operatorPanel"
        android:layout_width="168dp"
        android:layout_height="196dp"
        android:columnCount="2"
        android:rowCount="3"
        android:useDefaultMargins="true"
        app:layout_constraintBottom_toBottomOf="@id/mainArea"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@id/mainArea">

        <Button
            android:id="@+id/btnOpLeftBracket"
            android:layout_width="72dp"
            android:layout_height="56dp"
            android:text="("
            android:textAllCaps="false"
            android:textSize="22sp"
            android:textStyle="bold" />

        <Button
            android:id="@+id/btnOpRightBracket"
            android:layout_width="72dp"
            android:layout_height="56dp"
            android:text=")"
            android:textAllCaps="false"
            android:textSize="22sp"
            android:textStyle="bold" />

        <Button
            android:id="@+id/btnOpPlus"
            android:layout_width="72dp"
            android:layout_height="56dp"
            android:text="+"
            android:textAllCaps="false"
            android:textSize="22sp"
            android:textStyle="bold" />

        <Button
            android:id="@+id/btnOpMinus"
            android:layout_width="72dp"
            android:layout_height="56dp"
            android:text="-"
            android:textAllCaps="false"
            android:textSize="22sp"
            android:textStyle="bold" />

        <Button
            android:id="@+id/btnOpMultiply"
            android:layout_width="72dp"
            android:layout_height="56dp"
            android:text="*"
            android:textAllCaps="false"
            android:textSize="22sp"
            android:textStyle="bold" />

        <Button
            android:id="@+id/btnOpDivide"
            android:layout_width="72dp"
            android:layout_height="56dp"
            android:text="/"
            android:textAllCaps="false"
            android:textSize="22sp"
            android:textStyle="bold" />
    </GridLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
