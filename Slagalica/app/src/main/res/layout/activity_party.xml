<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:id="@+id/tvPartyTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="48dp"
            android:layout_marginBottom="10dp"
            android:gravity="center"
            android:text="Regularna partija"
            android:textColor="#1E1E1E"
            android:textSize="30sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvPartyProfileLine"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="28dp"
            android:gravity="center"
            android:text="Tokeni: - | Zvezde: - | Liga: -"
            android:textColor="#666666"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/tvPartyPlayers"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:gravity="center"
            android:text="Igrac 1 vs Igrac 2"
            android:textColor="#222222"
            android:textSize="20sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvPartyCurrentGame"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:gravity="center"
            android:text="Igra 1/6"
            android:textColor="#333333"
            android:textSize="18sp" />

        <TextView
            android:id="@+id/tvPartyTotalScore"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            android:gravity="center"
            android:text="Ukupno: 0 : 0"
            android:textColor="#6200EE"
            android:textSize="22sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvPartyStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="32dp"
            android:gravity="center"
            android:text="Priprema partije..."
            android:textColor="#666666"
            android:textSize="16sp" />

        <Button
            android:id="@+id/btnPartyPrimary"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:layout_marginBottom="14dp"
            android:text="Nastavi igru"
            android:textAllCaps="false"
            android:textSize="16sp" />

        <Button
            android:id="@+id/btnPartyForfeit"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:text="Odustani"
            android:textAllCaps="false"
            android:textSize="16sp" />

    </LinearLayout>
</ScrollView>
