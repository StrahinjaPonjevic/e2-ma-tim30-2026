<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F5F5F5">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        android:gravity="center_vertical"
        android:background="#F5F5F5">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">

            <TextView
                android:id="@+id/tvPlayer1Name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Igrač 1"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="#1E1E1E"/>

            <TextView
                android:id="@+id/tvPlayer1Score"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0 bodova"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="#6200EE"/>
        </LinearLayout>

        <FrameLayout
            android:layout_width="72dp"
            android:layout_height="72dp"
            android:gravity="center">

            <com.google.android.material.progressindicator.CircularProgressIndicator
                android:id="@+id/progressTimer"
                android:layout_width="72dp"
                android:layout_height="72dp"
                android:layout_gravity="center"
                app:indicatorColor="#6200EE"
                app:trackColor="#E0E0E0"
                app:trackThickness="6dp"
                app:indicatorSize="72dp"/>

            <TextView
                android:id="@+id/tvTimer"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:text="120"
                android:textSize="22sp"
                android:textStyle="bold"
                android:textColor="#1E1E1E"/>
        </FrameLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">

            <TextView
                android:id="@+id/tvPlayer2Name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Igrač 2"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="#1E1E1E"/>

            <TextView
                android:id="@+id/tvPlayer2Score"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0 bodova"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="#6200EE"/>
        </LinearLayout>
    </LinearLayout>

    <TextView
        android:id="@+id/tvRoundLabel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="RUNDA 1 — PRONAĐI TAČNU ASOCIJACIJU"
        android:textSize="12sp"
        android:textColor="#666666"
        android:gravity="center"
        android:paddingBottom="8dp"/>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#E0E0E0"
        android:layout_marginHorizontal="16dp"/>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:overScrollMode="never"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="12dp"
            android:paddingVertical="10dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="6dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginEnd="4dp">


                    <Button
                        android:id="@+id/cellA1"
                        android:layout_width="match_parent"
                        android:layout_height="55dp"
                        android:text="A1"
                        android:textAllCaps="false"
                        android:textSize="13sp"
                        android:textColor="#FFFFFF"
                        android:backgroundTint="#5C4DB1"
                        android:layout_marginTop="3dp"/>

                    <Button
                        android:id="@+id/cellA2"
                        android:layout_width="match_parent"
                        android:layout_height="55dp"
                        android:text="A2"
                        android:textAllCaps="false"
                        android:textSize="13sp"
                        android:textColor="#FFFFFF"
                        android:backgroundTint="#5C4DB1"
                        android:layout_marginTop="3dp"/>

                    <Button
                        android:id="@+id/cellA3"
                        android:layout_width="match_parent"
                        android:layout_height="55dp"
                        android:text="A3"
                        android:textAllCaps="false"
                        android:textSize="13sp"
                        android:textColor="#FFFFFF"
                        android:backgroundTint="#5C4DB1"
                        android:layout_marginTop="3dp"/>

                    <Button
                        android:id="@+id/cellA4"
                        android:layout_width="match_parent"
                        android:layout_height="55dp"
                        android:text="A4"
                        android:textAllCaps="false"
                        android:textSize="13sp"
                        android:textColor="#FFFFFF"
                        android:backgroundTint="#5C4DB1"
                        android:layout_marginTop="3dp"/>

                </LinearLayout>

                <!-- Kolona B -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginStart="4dp">


                    <Button
                        android:id="@+id/cellB1"
                        android:layout_width="match_parent"
                        android:layout_height="55dp"
                        android:text="B1"
                        android:textAllCaps="false"
                        android:textSize="13sp"
                        android:textColor="#FFFFFF"
                        android:backgroundTint="#7B5EA7"
                        android:layout_marginTop="3dp"/>

                    <Button
                        android:id="@+id/cellB2"
                        android:layout_width="match_parent"
                        android:layout_height="55dp"
                        android:text="B2"
                        android:textAllCaps="false"
                        android:textSize="13sp"
                        android:textColor="#FFFFFF"
                        android:backgroundTint="#7B5EA7"
                        android:layout_marginTop="3dp"/>

                    <Button
                        android:id="@+id/cellB3"
                        android:layout_width="match_parent"
                        android:layout_height="55dp"
                        android:text="B3"
                        android:textAllCaps="false"
                        android:textSize="13sp"
                        android:textColor="#FFFFFF"
                        android:backgroundTint="#7B5EA7"
                        android:layout_marginTop="3dp"/>

                    <Button
                        android:id="@+id/cellB4"
                        android:layout_width="match_parent"
                        android:layout_height="55dp"
                        android:text="B4"
                        android:textAllCaps="false"
                        android:textSize="13sp"
                        android:textColor="#FFFFFF"
                        android:backgroundTint="#7B5EA7"
                        android:layout_marginTop="3dp"/>

                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="4dp">

                <TextView
                    android:id="@+id/tvAnswerA"
                    android:layout_width="0dp"
                    android:layout_height="52dp"
                    android:layout_weight="1"
                    android:text="Rešenje A"
                    android:textSize="12sp"
                    android:textColor="#FFFFFF"
                    android:gravity="center"
                    android:background="#5C4DB1"
                    android:alpha="0.45"
                    android:layout_marginEnd="4dp"/>

                <TextView
                    android:id="@+id/tvAnswerB"
                    android:layout_width="0dp"
                    android:layout_height="52dp"
                    android:layout_weight="1"
                    android:text="Rešenje B"
                    android:textSize="12sp"
                    android:textColor="#FFFFFF"
                    android:gravity="center"
                    android:background="#7B5EA7"
                    android:alpha="0.45"
                    android:layout_marginStart="4dp"/>
            </LinearLayout>

            <TextView
                android:id="@+id/tvAnswerFinal"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="KRAJNJE REŠENJE"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:gravity="center"
                android:background="#6200EE"
                android:alpha="0.45"
                android:layout_marginBottom="4dp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="6dp">

                <TextView
                    android:id="@+id/tvAnswerC"
                    android:layout_width="0dp"
                    android:layout_height="52dp"
                    android:layout_weight="1"
                    android:text="Rešenje C"
                    android:textSize="12sp"
                    android:textColor="#FFFFFF"
                    android:gravity="center"
                    android:background="#9C6FBE"
                    android:alpha="0.45"
                    android:layout_marginEnd="4dp"/>

                <TextView
                    android:id="@+id/tvAnswerD"
                    android:layout_width="0dp"
                    android:layout_height="52dp"
                    android:layout_weight="1"
                    android:text="Rešenje D"
                    android:textSize="12sp"
                    android:textColor="#FFFFFF"
                    android:gravity="center"
                    android:background="#B48FD4"
                    android:alpha="0.45"
                    android:layout_marginStart="4dp"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginEnd="4dp">

                    <Button
                        android:id="@+id/cellC4"
                        android:layout_width="match_parent"
                        android:layout_height="55dp"
                        android:text="C4"
                        android:textAllCaps="false"
                        android:textSize="13sp"
                        android:textColor="#FFFFFF"
                        android:backgroundTint="#9C6FBE"
                        android:layout_marginBottom="3dp"/>

                    <Button
                        android:id="@+id/cellC3"
                        android:layout_width="match_parent"
                        android:layout_height="55dp"
                        android:text="C3"
                        android:textAllCaps="false"
                        android:textSize="13sp"
                        android:textColor="#FFFFFF"
                        android:backgroundTint="#9C6FBE"
                        android:layout_marginBottom="3dp"/>

                    <Button
                        android:id="@+id/cellC2"
                        android:layout_width="match_parent"
                        android:layout_height="55dp"
                        android:text="C2"
                        android:textAllCaps="false"
                        android:textSize="13sp"
                        android:textColor="#FFFFFF"
                        android:backgroundTint="#9C6FBE"
                        android:layout_marginBottom="3dp"/>

                    <Button
                        android:id="@+id/cellC1"
                        android:layout_width="match_parent"
                        android:layout_height="55dp"
                        android:text="C1"
                        android:textAllCaps="false"
                        android:textSize="13sp"
                        android:textColor="#FFFFFF"
                        android:backgroundTint="#9C6FBE"
                        android:layout_marginBottom="3dp"/>



                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginStart="4dp">

                    <Button
                        android:id="@+id/cellD4"
                        android:layout_width="match_parent"
                        android:layout_height="55dp"
                        android:text="D4"
                        android:textAllCaps="false"
                        android:textSize="13sp"
                        android:textColor="#FFFFFF"
                        android:backgroundTint="#B48FD4"
                        android:layout_marginBottom="3dp"/>

                    <Button
                        android:id="@+id/cellD3"
                        android:layout_width="match_parent"
                        android:layout_height="55dp"
                        android:text="D3"
                        android:textAllCaps="false"
                        android:textSize="13sp"
                        android:textColor="#FFFFFF"
                        android:backgroundTint="#B48FD4"
                        android:layout_marginBottom="3dp"/>

                    <Button
                        android:id="@+id/cellD2"
                        android:layout_width="match_parent"
                        android:layout_height="55dp"
                        android:text="D2"
                        android:textAllCaps="false"
                        android:textSize="13sp"
                        android:textColor="#FFFFFF"
                        android:backgroundTint="#B48FD4"
                        android:layout_marginBottom="3dp"/>

                    <Button
                        android:id="@+id/cellD1"
                        android:layout_width="match_parent"
                        android:layout_height="55dp"
                        android:text="D1"
                        android:textAllCaps="false"
                        android:textSize="13sp"
                        android:textColor="#FFFFFF"
                        android:backgroundTint="#B48FD4"
                        android:layout_marginBottom="3dp"/>


                </LinearLayout>
            </LinearLayout>

        </LinearLayout>
    </ScrollView>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#E0E0E0"
        android:layout_marginHorizontal="16dp"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#F5F5F5"
        android:paddingHorizontal="24dp"
        android:paddingTop="12dp"
        android:paddingBottom="16dp">

        <EditText
            android:id="@+id/etGuess"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:hint="Upiši rešenje kolone ili finalno..."
            android:textColor="#1E1E1E"
            android:textColorHint="#BDBDBD"
            android:textSize="14sp"
            android:gravity="center"
            android:inputType="text"
            android:imeOptions="actionDone"
            android:layout_marginBottom="10dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginBottom="8dp">

            <Button
                android:id="@+id/btnClear"
                android:layout_width="0dp"
                android:layout_height="55dp"
                android:layout_weight="1"
                android:text="Briši"
                android:textAllCaps="false"
                android:textSize="14sp"
                android:layout_marginEnd="4dp"/>

            <Button
                android:id="@+id/btnPass"
                android:layout_width="0dp"
                android:layout_height="55dp"
                android:layout_weight="1"
                android:text="Dalje"
                android:textAllCaps="false"
                android:textSize="14sp"
                android:layout_marginHorizontal="4dp"/>

            <Button
                android:id="@+id/btnConfirm"
                android:layout_width="0dp"
                android:layout_height="55dp"
                android:layout_weight="1"
                android:text="Potvrdi"
                android:textAllCaps="false"
                android:textSize="14sp"
                android:layout_marginStart="4dp"/>
        </LinearLayout>

        <Button
            android:id="@+id/btnBack"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:text="Nazad"
            android:textAllCaps="false"
            android:textSize="16sp"/>

    </LinearLayout>

</LinearLayout>