<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F5F5F5">

    <include layout="@layout/view_game_header" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="#F5F5F5">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <TextView
                android:id="@+id/tvQuestionCounter"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Pitanje 1/5"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#333333"
                android:gravity="center"
                android:layout_marginBottom="16dp" />

            <TextView
                android:id="@+id/tvTurnInfo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Na potezu: Igrač 1"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#6200EE"
                android:gravity="center"
                android:layout_marginBottom="16dp" />

            <TextView
                android:id="@+id/tvQuestion"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Koji je glavni grad Srbije?"
                android:textSize="22sp"
                android:textStyle="bold"
                android:textColor="#1E1E1E"
                android:gravity="center"
                android:background="#FFFFFF"
                android:padding="18dp"
                android:layout_marginBottom="20dp" />

            <Button
                android:id="@+id/btnAnswerA"
                android:layout_width="match_parent"
                android:layout_height="55dp"
                android:text="A) Novi Sad"
                android:textAllCaps="false"
                android:textSize="16sp"
                android:layout_marginBottom="10dp" />

            <Button
                android:id="@+id/btnAnswerB"
                android:layout_width="match_parent"
                android:layout_height="55dp"
                android:text="B) Beograd"
                android:textAllCaps="false"
                android:textSize="16sp"
                android:layout_marginBottom="10dp" />

            <Button
                android:id="@+id/btnAnswerC"
                android:layout_width="match_parent"
                android:layout_height="55dp"
                android:text="C) Niš"
                android:textAllCaps="false"
                android:textSize="16sp"
                android:layout_marginBottom="10dp" />

            <Button
                android:id="@+id/btnAnswerD"
                android:layout_width="match_parent"
                android:layout_height="55dp"
                android:text="D) Kragujevac"
                android:textAllCaps="false"
                android:textSize="16sp"
                android:layout_marginBottom="20dp" />

            <Button
                android:id="@+id/btnNextQuestion"
                android:layout_width="match_parent"
                android:layout_height="55dp"
                android:text="Sledeće pitanje"
                android:textAllCaps="false"
                android:textSize="16sp"
                android:enabled="false"
                android:layout_marginBottom="12dp" />

            <Button
                android:id="@+id/btnBack"
                android:layout_width="match_parent"
                android:layout_height="55dp"
                android:text="Nazad"
                android:textAllCaps="false"
                android:textSize="16sp" />

        </LinearLayout>
    </ScrollView>

</LinearLayout>
