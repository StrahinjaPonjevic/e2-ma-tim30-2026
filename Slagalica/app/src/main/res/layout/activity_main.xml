<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="#F5F5F5">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="24dp"
        android:visibility="visible">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="40dp"
            android:layout_marginBottom="8dp"
            android:text="Slagalica"
            android:textColor="#1E1E1E"
            android:textSize="36sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="40dp"
            android:gravity="center"
            android:text="Mobilna kviz aplikacija"
            android:textColor="#666666"
            android:textSize="16sp" />

        <!-- Guest section (not logged in) -->
        <LinearLayout
            android:id="@+id/guestSection"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="vertical"
            android:visibility="gone">

            <Button
                android:id="@+id/btnOpenLogin"
                android:layout_width="match_parent"
                android:layout_height="55dp"
                android:layout_marginBottom="16dp"
                android:text="Prijava"
                android:textAllCaps="false"
                android:textSize="16sp" />

            <Button
                android:id="@+id/btnOpenRegister"
                android:layout_width="match_parent"
                android:layout_height="55dp"
                android:layout_marginBottom="16dp"
                android:text="Registracija"
                android:textAllCaps="false"
                android:textSize="16sp" />

            <Button
                android:id="@+id/btnOpenPlayGuest"
                android:layout_width="match_parent"
                android:layout_height="55dp"
                android:layout_marginBottom="16dp"
                android:text="Igraj"
                android:textAllCaps="false"
                android:textSize="16sp" />

        </LinearLayout>

        <!-- Logged-in section -->
        <LinearLayout
            android:id="@+id/loggedInSection"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="vertical"
            android:visibility="visible">

            <Button
                android:id="@+id/btnOpenProfile"
                android:layout_width="75dp"
                android:layout_height="75dp"
                android:layout_gravity="center"
                android:layout_marginBottom="24dp"
                android:text="P"
                android:textAllCaps="false"
                android:textSize="20sp" />

            <TextView
                android:id="@+id/tvLoggedInUser"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:gravity="center"
                android:text=""
                android:textColor="#222222"
                android:textSize="18sp" />

            <TextView
                android:id="@+id/tvTokensStars"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="32dp"
                android:gravity="center"
                android:text=""
                android:textColor="#666666"
                android:textSize="14sp" />

            <Button
                android:id="@+id/btnOpenPlayLoggedIn"
                android:layout_width="match_parent"
                android:layout_height="55dp"
                android:layout_marginBottom="16dp"
                android:text="Igraj regularnu partiju"
                android:textAllCaps="false"
                android:textSize="16sp" />

            <Button
                android:id="@+id/btnOpenFriendly"
                android:layout_width="match_parent"
                android:layout_height="55dp"
                android:layout_marginBottom="16dp"
                android:text="Prijateljska partija"
                android:textAllCaps="false"
                android:textSize="16sp" />

            <Button
                android:id="@+id/btnOpenChat"
                android:layout_width="match_parent"
                android:layout_height="55dp"
                android:layout_marginBottom="16dp"
                android:text="Cet"
                android:textAllCaps="false"
                android:textSize="16sp" />

            <Button
                android:id="@+id/btnOpenChallenges"
                android:layout_width="match_parent"
                android:layout_height="55dp"
                android:layout_marginBottom="16dp"
                android:text="Izazovi"
                android:textAllCaps="false"
                android:textSize="16sp" />

            <Button
                android:id="@+id/btnOpenRegions"
                android:layout_width="match_parent"
                android:layout_height="55dp"
                android:layout_marginBottom="16dp"
                android:text="Regioni Srbije"
                android:textAllCaps="false"
                android:textSize="16sp" />

            <Button
                android:id="@+id/btnOpenNotifications"
                android:layout_width="match_parent"
                android:layout_height="55dp"
                android:layout_marginBottom="16dp"
                android:text="Notifikacije"
                android:textAllCaps="false"
                android:textSize="16sp" />

        </LinearLayout>

    </LinearLayout>

</ScrollView>
