<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="#F5F5F5">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Korak po korak"
            android:textSize="30sp"
            android:textStyle="bold"
            android:textColor="#1E1E1E"
            android:gravity="center"
            android:layout_marginBottom="8dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Pogodite traženi pojam kroz najviše 7 koraka"
            android:textSize="15sp"
            android:textColor="#666666"
            android:gravity="center"
            android:layout_marginBottom="24dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Runda: 1/2"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#1E1E1E" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Vreme: 70s"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#1E1E1E"
                android:gravity="end" />

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="24dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Igrač 1: 0"
                android:textSize="16sp"
                android:textColor="#333333" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Igrač 2: 0"
                android:textSize="16sp"
                android:textColor="#333333"
                android:gravity="end" />

        </LinearLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="Korak 1: __________"
            android:textSize="16sp"
            android:gravity="center_vertical"
            android:padding="12dp"
            android:background="@android:drawable/edit_text"
            android:layout_marginBottom="10dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="Korak 2: __________"
            android:textSize="16sp"
            android:gravity="center_vertical"
            android:padding="12dp"
            android:background="@android:drawable/edit_text"
            android:layout_marginBottom="10dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="Korak 3: __________"
            android:textSize="16sp"
            android:gravity="center_vertical"
            android:padding="12dp"
            android:background="@android:drawable/edit_text"
            android:layout_marginBottom="10dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="Korak 4: __________"
            android:textSize="16sp"
            android:gravity="center_vertical"
            android:padding="12dp"
            android:background="@android:drawable/edit_text"
            android:layout_marginBottom="10dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="Korak 5: __________"
            android:textSize="16sp"
            android:gravity="center_vertical"
            android:padding="12dp"
            android:background="@android:drawable/edit_text"
            android:layout_marginBottom="10dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="Korak 6: __________"
            android:textSize="16sp"
            android:gravity="center_vertical"
            android:padding="12dp"
            android:background="@android:drawable/edit_text"
            android:layout_marginBottom="10dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="Korak 7: __________"
            android:textSize="16sp"
            android:gravity="center_vertical"
            android:padding="12dp"
            android:background="@android:drawable/edit_text"
            android:layout_marginBottom="20dp" />

        <EditText
            android:id="@+id/etAnswer"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:hint="Unesite konačan pojam"
            android:inputType="text"
            android:padding="12dp"
            android:background="@android:drawable/edit_text"
            android:layout_marginBottom="16dp" />

        <Button
            android:id="@+id/btnConfirmAnswer"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:text="Potvrdi odgovor"
            android:textAllCaps="false"
            android:textSize="16sp"
            android:layout_marginBottom="12dp" />

        <Button
            android:id="@+id/btnNextStep"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:text="Otvori sledeći korak"
            android:textAllCaps="false"
            android:textSize="16sp"
            android:layout_marginBottom="12dp" />

        <Button
            android:id="@+id/btnGiveUp"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:text="Odustani"
            android:textAllCaps="false"
            android:textSize="16sp" />

    </LinearLayout>

</ScrollView>